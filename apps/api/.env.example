# Servidor
PORT=3000
NODE_ENV=development

# Auth (Google OAuth + JWT)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=

# URLs públicas (CORS, redirects OAuth e cookies)
API_BASE_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3001
POST_LOGIN_REDIRECT_URL=http://localhost:3001

# Produção (Render + Vercel)
# API_BASE_URL=
# FRONTEND_BASE_URL=https://seu-projeto.vercel.app
# POST_LOGIN_REDIRECT_URL=https://seu-projeto.vercel.app/home
# FRONTEND_BASE_URL deve ser a URL exata do front na Vercel (CORS + handoff OAuth).
# Com hosts diferentes, o OAuth redireciona para /auth/callback no front com handoff.

# Callback OAuth no Google Cloud Console (opcional; padrão: {API_BASE_URL}/auth/google/callback)
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Domínio compartilhado dos cookies em produção (opcional; ex.: .loreforge.example.com)
# COOKIE_DOMAIN=

# Banco de dados (migrations Drizzle em drizzle/)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/loreforge

# Cache (Docker Compose sobrescreve hostname para redis:6379)
REDIS_URL=redis://localhost:6379

# Storage — MinIO local (Docker Compose sobrescreve S3_ENDPOINT para minio:9000)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=loreforge
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
